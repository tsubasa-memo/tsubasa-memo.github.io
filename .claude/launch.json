{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "静的サイト プレビュー (port 8080)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "drafts プレビュー (port 8081)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8081", "--directory", "drafts"],
      "port": 8081
    }
  ]
}
